  "components": {
    "shell:sidebar": {"key": "shell:sidebar", "name": "Shell / Sidebar", "description": "Vertical stack of 7 SidebarItem instances + brand mark at top. width=220 height=full."}
  },
  "styles": {
    "ref_chromatic_scheme_source": ".triage/chromatic-schemes.json#n=2 (DEEP CURRENT)",
    "note": "Every hex in this file is either from scheme #02 or identity-v2 neutrals. No invented values."
  },
  "meta": {
    "intended_upload_target": "claude.ai/design — 'Upload a .fig file' field",
    "format_rationale": "Figma REST API document-tree shape. Claude Design's .fig parse runs locally in browser, so it sees a standard Figma node tree — this JSON reconstructs that shape as if the file had been duplicated from Figma Community.",
    "recommended_usage": "If claude.ai/design rejects .json in the .fig field, paste this file contents into the 'Any other notes' field OR into a linked GitHub repo as figma-schema.json — Claude Design's agent will still parse structured JSON from there."
  }
}
