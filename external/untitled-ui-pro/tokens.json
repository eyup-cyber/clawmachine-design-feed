{
  "$schema": "https://schemas.untitledui.com/tokens.json",
  "source": "Extracted 1:1 from untitleduico/react@MIT styles/theme.css + styles/typography.css",
  "version": "v8 (React 19.2 / Tailwind v4.2)",
  "brand": "Untitled UI (default violet brand palette)",
  "font": {
    "body": ["Inter", "-apple-system", "Segoe UI", "Roboto", "Arial", "sans-serif"],
    "display": ["Inter", "-apple-system", "Segoe UI", "Roboto", "Arial", "sans-serif"],
    "mono": ["ui-monospace", "Roboto Mono", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "Liberation Mono", "Courier New", "monospace"]
  },
  "spacing": {
    "unit": "0.25rem",
    "note": "Tailwind v4 --spacing default of 0.25rem (4px) drives all --text-* and gap scales"
  },
  "text": {
    "xs":         { "size": "12px", "line": "18px" },
    "sm":         { "size": "14px", "line": "20px" },
    "md":         { "size": "16px", "line": "24px" },
    "lg":         { "size": "18px", "line": "28px" },
    "xl":         { "size": "20px", "line": "30px" },
    "display-xs": { "size": "24px", "line": "32px" },
    "display-sm": { "size": "30px", "line": "38px" },
    "display-md": { "size": "36px", "line": "44px", "tracking": "-0.72px" },
    "display-lg": { "size": "48px", "line": "60px", "tracking": "-0.96px" },
    "display-xl": { "size": "60px", "line": "72px", "tracking": "-1.2px" },
    "display-2xl":{ "size": "72px", "line": "90px", "tracking": "-1.44px" }
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "10px",
    "2xl": "12px",
    "3xl": "16px",
    "4xl": "20px"
  },
  "shadow": {
    "xs": "0px 1px 2px rgba(0,0,0,0.05)",
    "sm": "0px 1px 3px rgba(0,0,0,0.1), 0px 1px 2px -1px rgba(0,0,0,0.1)",
    "md": "0px 4px 6px -1px rgba(0,0,0,0.1), 0px 2px 4px -2px rgba(0,0,0,0.06)",
    "lg": "0px 12px 16px -4px rgba(0,0,0,0.08), 0px 4px 6px -2px rgba(0,0,0,0.03), 0px 2px 2px -1px rgba(0,0,0,0.04)",
    "xl": "0px 20px 24px -4px rgba(0,0,0,0.08), 0px 8px 8px -4px rgba(0,0,0,0.03), 0px 3px 3px -1.5px rgba(0,0,0,0.04)",
    "2xl": "0px 24px 48px -12px rgba(0,0,0,0.18), 0px 4px 4px -2px rgba(0,0,0,0.04)",
    "3xl": "0px 32px 64px -12px rgba(0,0,0,0.14), 0px 5px 5px -2.5px rgba(0,0,0,0.04)",
    "skeuomorphic": "0px 0px 0px 1px rgba(0,0,0,0.18) inset, 0px -2px 0px 0px rgba(0,0,0,0.05) inset",
    "xs-skeuomorphic": "0px 0px 0px 1px rgba(0,0,0,0.18) inset, 0px -2px 0px 0px rgba(0,0,0,0.05) inset, 0px 1px 2px rgba(0,0,0,0.05)"
  },
  "breakpoint": {
    "xxs": "320px",
    "xs": "600px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "container": { "max": "1280px" },
  "color": {
    "brand": {
      "50":  "rgb(249 245 255)",
      "100": "rgb(244 235 255)",
      "200": "rgb(233 215 254)",
      "300": "rgb(214 187 251)",
      "400": "rgb(182 146 246)",
      "500": "rgb(158 119 237)",
      "600": "rgb(127 86 217)",
      "700": "rgb(105 65 198)",
      "800": "rgb(83 56 158)",
      "900": "rgb(66 48 125)",
      "950": "rgb(44 28 95)"
    },
    "neutral": {
      "25":  "rgb(253 253 253)",
      "50":  "rgb(250 250 250)",
      "100": "rgb(245 245 245)",
      "200": "rgb(229 229 229)",
      "300": "rgb(212 212 212)",
      "400": "rgb(163 163 163)",
      "500": "rgb(115 115 115)",
      "600": "rgb(82 82 82)",
      "700": "rgb(64 64 64)",
      "800": "rgb(38 38 38)",
      "900": "rgb(23 23 23)",
      "950": "rgb(12 14 18)"
    },
    "error":  { "50": "rgb(254 242 242)", "100": "rgb(254 226 226)", "200": "rgb(254 202 202)", "300": "rgb(252 165 165)", "400": "rgb(248 113 113)", "500": "rgb(239 68 68)", "600": "rgb(220 38 38)", "700": "rgb(185 28 28)", "800": "rgb(153 27 27)", "900": "rgb(127 29 29)", "950": "rgb(69 10 10)" },
    "warning":{ "50": "rgb(254 252 232)", "100": "rgb(254 249 195)", "200": "rgb(254 240 138)", "300": "rgb(253 224 71)",  "400": "rgb(250 204 21)",  "500": "rgb(234 179 8)",  "600": "rgb(202 138 4)",  "700": "rgb(161 98 7)",  "800": "rgb(133 77 14)",  "900": "rgb(113 63 18)",  "950": "rgb(66 32 6)" },
    "success":{ "50": "rgb(240 253 244)", "100": "rgb(220 252 231)", "200": "rgb(187 247 208)", "300": "rgb(134 239 172)", "400": "rgb(74 222 128)",  "500": "rgb(34 197 94)",  "600": "rgb(22 163 74)",  "700": "rgb(21 128 61)",  "800": "rgb(22 101 52)",  "900": "rgb(20 83 45)",   "950": "rgb(5 46 22)" }
  },
  "semantic_light": {
    "text-primary":        "neutral-900",
    "text-secondary":      "neutral-700",
    "text-tertiary":       "neutral-600",
    "text-quaternary":     "neutral-500",
    "text-placeholder":    "neutral-500",
    "text-brand-primary":  "brand-900",
    "text-brand-secondary":"brand-700",
    "text-brand-tertiary": "brand-600",
    "text-error-primary":  "error-600",
    "text-warning-primary":"warning-600",
    "text-success-primary":"success-600",
    "border-primary":      "neutral-300",
    "border-secondary":    "neutral-200",
    "border-tertiary":     "neutral-100",
    "border-brand":        "brand-500",
    "border-error":        "error-500",
    "fg-primary":          "neutral-900",
    "fg-secondary":        "neutral-700",
    "fg-tertiary":         "neutral-600",
    "fg-quaternary":       "neutral-400",
    "fg-brand-primary":    "brand-600",
    "fg-brand-secondary":  "brand-500",
    "fg-error-primary":    "error-600",
    "fg-warning-primary":  "warning-600",
    "fg-success-primary":  "success-600",
    "bg-primary":          "#FFFFFF",
    "bg-primary_hover":    "neutral-50",
    "bg-secondary":        "neutral-50",
    "bg-secondary_hover":  "neutral-100",
    "bg-tertiary":         "neutral-100",
    "bg-quaternary":       "neutral-200",
    "bg-brand-primary":    "brand-50",
    "bg-brand-secondary":  "brand-100",
    "bg-brand-solid":      "brand-600",
    "bg-brand-solid_hover":"brand-700",
    "bg-error-primary":    "error-50",
    "bg-error-solid":      "error-600",
    "bg-warning-primary":  "warning-50",
    "bg-warning-solid":    "warning-600",
    "bg-success-primary":  "success-50",
    "bg-success-solid":    "success-600"
  },
  "semantic_dark": {
    "text-primary":        "neutral-50",
    "text-secondary":      "neutral-300",
    "text-tertiary":       "neutral-400",
    "text-quaternary":     "neutral-400",
    "text-placeholder":    "neutral-500",
    "bg-primary":          "neutral-950",
    "bg-primary_hover":    "neutral-900",
    "bg-secondary":        "neutral-900",
    "bg-secondary_hover":  "neutral-800",
    "bg-tertiary":         "neutral-800",
    "bg-quaternary":       "neutral-700",
    "border-primary":      "neutral-700",
    "border-secondary":    "neutral-800",
    "border-tertiary":     "neutral-800"
  },
  "component": {
    "button": {
      "sizes": {
        "xs": { "padding": "1.5px 10px", "h": "32px", "text": "sm", "radius": "lg" },
        "sm": { "padding": "8px 12px",  "h": "36px", "text": "sm", "radius": "lg" },
        "md": { "padding": "10px 14px", "h": "40px", "text": "sm", "radius": "lg" },
        "lg": { "padding": "10px 16px", "h": "44px", "text": "md", "radius": "lg" },
        "xl": { "padding": "12px 18px", "h": "48px", "text": "md", "radius": "lg" }
      },
      "colors": ["primary","secondary","tertiary","link-gray","link-color","primary-destructive","secondary-destructive","tertiary-destructive","link-destructive"]
    },
    "input": {
      "sizes": { "sm": { "h": "36px" }, "md": { "h": "40px" }, "lg": { "h": "44px" } },
      "radius": "lg",
      "shadow_default": "xs",
      "ring_default": "1px inset border-primary",
      "ring_focus":   "4px rgba(158,119,237,0.24) + 1px inset brand-500"
    },
    "badge": {
      "sizes": { "sm": { "h": "22px" }, "md": { "h": "24px" }, "lg": { "h": "28px" } },
      "types": ["pill-color","color","modern"],
      "colors": ["gray","brand","error","warning","success","blue","indigo","purple","pink","rose","orange","sky","slate"]
    },
    "avatar": {
      "sizes": { "xs": "24px", "sm": "32px", "md": "40px", "lg": "48px", "xl": "56px", "2xl": "64px" }
    },
    "featured-icon": {
      "themes": ["light","gradient","dark","modern","modern-neue","outline"],
      "sizes": { "sm": "32px", "md": "40px", "lg": "48px", "xl": "56px" }
    },
    "card": {
      "radius_outer": "xl",
      "shadow": "sm",
      "border": "1px border-secondary",
      "bg": "bg-primary",
      "pad": "24px"
    },
    "modal": { "radius": "xl", "shadow": "2xl", "max_w": "480px" },
    "tooltip": { "radius": "md", "bg_dark": "neutral-900", "text": "white", "pad": "6px 10px", "text_size": "xs" }
  }
}
