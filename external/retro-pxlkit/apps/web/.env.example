# ==========================================
# PXLKIT LICENSING ENVIRONMENT VARIABLES
# ==========================================

# 1. PAYPAL (SANDBOX / LIVE)
# Para pruebas locales usa las credenciales de Sandbox.
# En Vercel Producción, usa las credenciales de Live App.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Compatibilidad (opcional): también puedes definir este alias con el mismo valor
PAYPAL_CLIENT_SECRET=

# 2. RESEND (EMAIL)
# Tu API key de Resend. En el plan gratuito solo puedes enviar correos a tu email verificado.
# Para enviar a cualquiera, necesitas agregar un dominio y verificarlo en Resend.
RESEND_API_KEY=

# 3. BASE DE DATOS (VERCEL KV)
# La forma más rápida, sencilla y profesional de guardar licencias.
# Crea un Vercel KV Storage desde tu panel de Vercel y enlaza este proyecto.
# Vercel llenará estas variables automáticamente, pero si pruebas localmente, cópialas aquí:
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
