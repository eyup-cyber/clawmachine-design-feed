{
  "name": "@pxlkit/ui",
  "version": "1.2.3",
  "description": "UI & interface pixel art icon pack \u2014 41 icons for tools, controls, navigation, editor elements, home, search, settings, menus, and layout",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "ui",
    "interface",
    "controls",
    "retro",
    "pxlkit",
    "navigation-icons",
    "home-icon",
    "search-icon",
    "settings-icon",
    "menu-icon",
    "editor-icons",
    "toolbar-icons",
    "layout-icons",
    "svg-icons",
    "react-icons",
    "source-available-icons",
    "free-ui-icons",
    "8-bit-icons"
  ]
}
