{
  "name": "@pxlkit/feedback",
  "version": "1.2.3",
  "description": "Feedback and notification pixel art icon pack \u2014 33 icons for alerts, status indicators, checkmarks, shields, bugs, badges, and toast notifications",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "feedback",
    "notification",
    "toast",
    "ui",
    "alert-icons",
    "status-icons",
    "checkmark-icon",
    "shield-icon",
    "badge-icon",
    "warning-icon",
    "error-icon",
    "success-icon",
    "svg-icons",
    "react-icons",
    "pxlkit",
    "source-available-icons",
    "free-notification-icons",
    "8-bit-icons",
    "retro-icons"
  ]
}
