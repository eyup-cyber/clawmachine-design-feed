{
  "name": "@pxlkit/core",
  "version": "1.2.3",
  "description": "Core rendering engine, React components, SVG utilities, and TypeScript types for the Pxlkit pixel art toolkit \u2014 tree-shakeable icon renderer, animated icon player, 3D parallax icons, toast notifications, and color utilities",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "svg",
    "react",
    "retro",
    "8bit",
    "16bit",
    "pxlkit",
    "pixel-art-icons",
    "react-icons",
    "svg-icons",
    "icon-library",
    "icon-renderer",
    "animated-icons",
    "parallax-3d",
    "toast-notifications",
    "tree-shakeable",
    "typescript",
    "react-components",
    "pixel-art-react",
    "retro-ui",
    "design-system",
    "icon-toolkit",
    "mit-license"
  ],
  "homepage": "https://pxlkit.xyz",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  }
}
