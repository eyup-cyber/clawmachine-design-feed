{
  "name": "@pxlkit/parallax",
  "version": "1.2.3",
  "description": "Multi-layer 3D parallax pixel art icons \u2014 10 interactive depth-based mouse-tracking icons with configurable perspective and layer separation",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "parallax",
    "3d",
    "interactive",
    "retro",
    "multi-layer",
    "3d-icons",
    "parallax-effect",
    "mouse-tracking",
    "depth-effect",
    "perspective-icons",
    "interactive-icons",
    "react-parallax",
    "svg-parallax",
    "pxlkit",
    "source-available-icons",
    "3d-pixel-art",
    "layered-icons",
    "css-3d-transform"
  ]
}
