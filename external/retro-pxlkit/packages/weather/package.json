{
  "name": "@pxlkit/weather",
  "version": "1.2.3",
  "description": "Weather and nature pixel art icon pack \u2014 36 icons for sun, rain, clouds, moon phases, temperature, storms, snow, and climate UI",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "weather",
    "nature",
    "environment",
    "ui",
    "sun-icon",
    "moon-icon",
    "rain-icon",
    "cloud-icon",
    "storm-icon",
    "snow-icon",
    "temperature-icon",
    "climate-icons",
    "moon-phases",
    "svg-icons",
    "react-icons",
    "pxlkit",
    "source-available-icons",
    "free-weather-icons",
    "8-bit-icons",
    "retro-icons",
    "animated-weather"
  ]
}
