{
  "name": "@pxlkit/gamification",
  "version": "1.2.3",
  "description": "Gamification icon pack \u2014 51 pixel art icons for RPG games, achievements, rewards, trophies, swords, potions, coins, stars, and gaming UI",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "gamification",
    "retro",
    "trophy",
    "gaming",
    "rpg-icons",
    "achievement-icons",
    "reward-icons",
    "game-ui-icons",
    "sword-icon",
    "potion-icon",
    "coin-icon",
    "star-icon",
    "pixel-art-game",
    "indie-game-icons",
    "8-bit-icons",
    "svg-icons",
    "react-icons",
    "pxlkit",
    "source-available-icons",
    "free-game-icons"
  ]
}
