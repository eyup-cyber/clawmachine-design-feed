{
  "name": "@pxlkit/voxel",
  "version": "0.1.3",
  "description": "MIT-licensed 3D voxel game engine for React \u2014 procedural world generation, biome systems, chunk-based terrain streaming, day/night cycles, physics, NPC frameworks, and entity management built on Three.js and React Three Fiber",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "MIT",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "voxel",
    "voxel-engine",
    "3d",
    "game-engine",
    "react-three-fiber",
    "three-js",
    "threejs",
    "procedural-generation",
    "procedural-terrain",
    "procedural-world",
    "infinite-terrain",
    "biome-generation",
    "chunk-based-rendering",
    "day-night-cycle",
    "npc-system",
    "physics-engine",
    "entity-framework",
    "react-game-engine",
    "mit-game-engine",
    "webgl",
    "browser-game",
    "indie-game-engine",
    "minecraft-like",
    "voxel-sandbox",
    "voxel-world",
    "react-3d",
    "r3f",
    "retro",
    "pxlkit",
    "perlin-noise",
    "terrain-generation",
    "world-builder",
    "game-development",
    "web-game-engine"
  ]
}
