{
  "name": "@pxlkit/social",
  "version": "1.2.3",
  "description": "Social and media pixel art icon pack \u2014 43 icons for community, emojis, messaging, hearts, shares, users, reactions, and social media UI",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/Joangeldelarosa/pxlkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.2.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "social",
    "media",
    "community",
    "ui",
    "emoji-icons",
    "heart-icon",
    "user-icon",
    "message-icon",
    "reaction-icons",
    "social-media-icons",
    "pixel-art-emoji",
    "svg-icons",
    "react-icons",
    "pxlkit",
    "source-available-icons",
    "free-social-icons",
    "8-bit-icons",
    "retro-icons"
  ]
}
