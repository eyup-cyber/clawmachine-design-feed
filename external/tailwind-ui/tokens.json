{
  "kit": "tailwind-ui",
  "source": "Tailwind UI (tailwindui.com) — inferred from public Tailwind Labs house style",
  "aesthetic": "Brand-neutral, utility-first, generous whitespace, subtle shadows, indigo accent on gray neutrals",
  "notes": "Tokens inferred from the public tailwindcss.com docs, the open Tailwind Labs GitHub repos (tailwindcss, headlessui), and the component files produced in this kit. No values extracted from the paid package.",

  "font": {
    "family_sans": "Inter, ui-sans-serif, system-ui, sans-serif",
    "family_mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "features": ["cv02", "cv03", "cv04", "cv11"],
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem",
      "7xl": "4.5rem"
    },
    "line_height_shortform": "tight (text-5xl/9, text-sm/6) — Tailwind v4 compressed size/leading syntax"
  },

  "color": {
    "brand_accent": {
      "name": "indigo",
      "scale": {
        "50": "#eef2ff",
        "100": "#e0e7ff",
        "200": "#c7d2fe",
        "300": "#a5b4fc",
        "400": "#818cf8",
        "500": "#6366f1",
        "600": "#4f46e5",
        "700": "#4338ca",
        "800": "#3730a3",
        "900": "#312e81",
        "950": "#1e1b4b"
      },
      "primary_button": "indigo-600",
      "primary_button_hover": "indigo-500",
      "link": "indigo-600",
      "link_hover": "indigo-500",
      "focus_ring": "indigo-600"
    },
    "neutral_gray": {
      "name": "gray",
      "scale": {
        "50": "#f9fafb",
        "100": "#f3f4f6",
        "200": "#e5e7eb",
        "300": "#d1d5db",
        "400": "#9ca3af",
        "500": "#6b7280",
        "600": "#4b5563",
        "700": "#374151",
        "800": "#1f2937",
        "900": "#111827",
        "950": "#030712"
      },
      "text_primary": "gray-900",
      "text_secondary": "gray-600",
      "text_muted": "gray-500",
      "border_default": "gray-200",
      "border_strong": "gray-300",
      "surface": "white",
      "surface_alt": "gray-50",
      "surface_dark": "gray-900"
    },
    "feedback": {
      "success": "green-600",
      "error": "red-600",
      "warning": "yellow-500",
      "info": "blue-600"
    },
    "badge_variants": {
      "neutral_bg": "gray-50",
      "neutral_text": "gray-600",
      "neutral_ring": "gray-500/10",
      "indigo_bg": "indigo-50",
      "indigo_text": "indigo-700",
      "indigo_ring": "indigo-700/10",
      "red_bg": "red-50",
      "red_text": "red-700",
      "red_ring": "red-600/10",
      "yellow_bg": "yellow-50",
      "yellow_text": "yellow-800",
      "yellow_ring": "yellow-600/20",
      "green_bg": "green-50",
      "green_text": "green-700",
      "green_ring": "green-600/20"
    }
  },

  "radius": {
    "sm": "0.125rem",
    "DEFAULT": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px",
    "common_button": "md (0.375rem)",
    "common_card": "lg (0.5rem) or 2xl (1rem)",
    "common_input": "md (0.375rem)",
    "common_modal": "lg (0.5rem)"
  },

  "shadow": {
    "xs": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "sm": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "DEFAULT": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "common_button": "shadow-xs",
    "common_card": "shadow-lg",
    "common_modal": "shadow-2xl",
    "ring_subtle": "ring-1 ring-gray-900/5",
    "ring_default": "ring-1 ring-gray-200"
  },

  "spacing": {
    "scale_step": "0.25rem (0.5, 1, 1.5, 2, 2.5, 3, 3.5, 4, 5, 6, 8, 10, 12, 14, 16, 20, 24, 32, 40, 48, 56, 64, 72, 80, 96)",
    "section_vertical_mobile": "py-16 sm:py-24 (4rem -> 6rem)",
    "section_vertical_desktop": "py-24 sm:py-32 (6rem -> 8rem)",
    "section_horizontal": "px-6 lg:px-8",
    "max_width_container": "max-w-7xl (80rem)",
    "max_width_prose": "max-w-2xl (42rem) for body, max-w-3xl for long-form content"
  },

  "focus": {
    "ring_style": "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600",
    "input_focus": "focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600",
    "keyboard_only": "prefer focus-visible over focus"
  },

  "motion": {
    "duration_xs": "100ms",
    "duration_sm": "150ms",
    "duration_md": "200ms",
    "duration_lg": "300ms",
    "easing_default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easing_in": "cubic-bezier(0.4, 0, 1, 1)",
    "easing_out": "cubic-bezier(0, 0, 0.2, 1)",
    "usage": "transition-colors 150ms for hovers, transition-opacity 300ms for overlays, transition-transform 300ms for drawers"
  },

  "component_patterns": {
    "primary_button": "bg-indigo-600 hover:bg-indigo-500 text-white rounded-md px-3.5 py-2.5 text-sm font-semibold shadow-xs",
    "secondary_button": "bg-white hover:bg-gray-50 text-gray-900 rounded-md px-3.5 py-2.5 text-sm font-semibold ring-1 ring-gray-300 ring-inset",
    "ghost_button": "text-sm/6 font-semibold text-gray-900",
    "input": "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6",
    "card": "rounded-lg bg-white shadow-xs ring-1 ring-gray-900/5",
    "modal_panel": "rounded-lg bg-white shadow-xl ring-1 ring-gray-900/5",
    "divider": "border-t border-gray-200",
    "announcement_pill": "rounded-full px-3 py-1 text-sm/6 ring-1 ring-gray-900/10 hover:ring-gray-900/20"
  },

  "accessibility": {
    "contrast_minimum": "WCAG AA (4.5:1 for text on white)",
    "touch_target_minimum": "44x44px",
    "skip_link_style": "sr-only focus:not-sr-only",
    "keyboard_focus_style": "always visible with focus-visible:outline-2 offset-2"
  }
}
