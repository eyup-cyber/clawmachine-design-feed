{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Catalyst UI Kit design tokens — reconstructed from the scraped API at https://catalyst.tailwindui.com/docs based on the visible markup and Tailwind Labs house style.",
  "font": {
    "family": {
      "sans": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"],
      "mono": ["ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "Liberation Mono", "Courier New", "monospace"]
    },
    "feature_settings": "'cv02', 'cv03', 'cv04', 'cv11'"
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.625rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px"
  },
  "spacing_scale": "Tailwind default (0.25rem base)",
  "color": {
    "light": {
      "surface": "#ffffff",
      "surface_raised": "#ffffff",
      "surface_overlay": "rgba(255,255,255,0.75)",
      "page_bg_mobile": "#ffffff",
      "page_bg_desktop": "#f4f4f5",
      "text_primary": "#09090b",
      "text_secondary": "#71717a",
      "text_muted": "#a1a1aa",
      "border": "rgba(9,9,11,0.1)",
      "border_soft": "rgba(9,9,11,0.05)",
      "focus_ring": "#3b82f6",
      "shadow_xs": "0 1px 2px 0 rgba(0,0,0,0.05)",
      "shadow_sm": "0 1px 3px 0 rgba(0,0,0,0.1),0 1px 2px -1px rgba(0,0,0,0.1)",
      "shadow_lg": "0 10px 15px -3px rgba(0,0,0,0.1),0 4px 6px -4px rgba(0,0,0,0.1)"
    },
    "dark": {
      "surface": "#18181b",
      "surface_raised": "rgba(24,24,27,0.75)",
      "surface_overlay": "rgba(39,39,42,0.75)",
      "page_bg_mobile": "#18181b",
      "page_bg_desktop": "#09090b",
      "text_primary": "#ffffff",
      "text_secondary": "#a1a1aa",
      "text_muted": "#71717a",
      "border": "rgba(255,255,255,0.1)",
      "border_soft": "rgba(255,255,255,0.05)",
      "focus_ring": "#3b82f6"
    },
    "accent": {
      "primary_solid_bg": "#18181b",
      "primary_solid_text": "#ffffff",
      "adaptive_variants": ["dark/zinc", "light", "dark/white"],
      "solid_palette": [
        "dark", "zinc", "white", "red", "orange", "amber", "yellow",
        "lime", "green", "emerald", "teal", "cyan", "sky", "blue",
        "indigo", "violet", "purple", "fuchsia", "pink", "rose"
      ]
    }
  },
  "typography": {
    "text_base_mobile": "1rem / 1.5",
    "text_base_desktop": "0.875rem / 1.4285714",
    "heading_mobile": "1.5rem / 2",
    "heading_desktop": "1.25rem / 2",
    "subheading_mobile": "1rem / 1.75",
    "subheading_desktop": "0.875rem / 1.5",
    "label_mobile": "1rem / 1.5",
    "label_desktop": "0.875rem / 1.5"
  },
  "component_sizing": {
    "button_padding_mobile_x": "0.875rem",
    "button_padding_mobile_y": "0.625rem",
    "button_padding_desktop_x": "0.75rem",
    "button_padding_desktop_y": "0.375rem",
    "input_radius": "0.625rem",
    "checkbox_radius": "0.3125rem",
    "checkbox_size_mobile": "1.125rem",
    "checkbox_size_desktop": "1rem",
    "avatar_radius_default": "20%",
    "navbar_icon_size": "1.25rem",
    "sidebar_icon_size": "1.25rem",
    "badge_icon_size": "1rem"
  },
  "motion": {
    "dialog_enter_ms": 100,
    "dialog_leave_ms": 100,
    "sidebar_drawer_ms": 300,
    "dropdown_leave_ms": 100,
    "easing_enter": "ease-out",
    "easing_leave": "ease-in"
  },
  "a11y": {
    "touch_target_minimum": "2.75rem",
    "focus_outline": "2px solid var(--color-blue-500)",
    "focus_outline_offset": "2px"
  }
}
